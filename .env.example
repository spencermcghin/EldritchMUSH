# EldritchMUSH — environment variables
#
# Copy to `.env` for local development; never commit the filled version.
# In production/UAT these are set as Railway variables on each service.
#
# Every var is OPTIONAL unless marked REQUIRED. Sensible defaults live
# in eldritchmush/server/conf/settings.py.

# ---------------------------------------------------------------------------
# Environment identity
# ---------------------------------------------------------------------------
# Railway sets RAILWAY_ENVIRONMENT_NAME automatically (production|uat|...).
# DEPLOY_ENV is only used when running locally.
DEPLOY_ENV=local

# Overrides SERVERNAME shown in welcome text, logs, etc. Defaults to
# `eldritchmush` in prod and `eldritchmush-<env>` otherwise.
# SERVERNAME=eldritchmush

# ---------------------------------------------------------------------------
# Hosts / CSRF — comma-separated. Merged with repo defaults so prod
# domains work out of the box; add UAT/custom domains here.
# ---------------------------------------------------------------------------
# ALLOWED_HOSTS=uat.eldritchmush.com,uat-eldritchmush.up.railway.app
# CSRF_TRUSTED_ORIGINS=https://uat.eldritchmush.com

# Used by allauth to generate OAuth callback URLs. Must match the
# primary public domain for this environment.
# SITE_DOMAIN=eldritchmush.com
# SITE_NAME=EldritchMUSH

# ---------------------------------------------------------------------------
# Secret key — REQUIRED for any non-local deployment.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
# Local dev can use the checked-in fallback in secret_settings.py.
# ---------------------------------------------------------------------------
# DJANGO_SECRET_KEY=change-me

# ---------------------------------------------------------------------------
# Bootstrap admin account — created once on first boot.
# ---------------------------------------------------------------------------
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=change-me
# ADMIN_EMAIL=admin@eldritchmush.com

# ---------------------------------------------------------------------------
# Google OAuth (Sign in with Google) — REQUIRED in UAT + prod.
# Get these from Google Cloud Console → APIs & Services → Credentials.
# Add https://<env-domain>/accounts/google/login/callback/ as an
# authorized redirect URI.
# ---------------------------------------------------------------------------
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# World-build toggles — run-once-on-deploy actions.
# ---------------------------------------------------------------------------
# Run world/populate_mistvale.py on boot (idempotent; safe to leave on).
# Recommended: 1 in UAT, 1 on initial prod deploy, 0 thereafter.
MISTVALE_BUILD=0

# Replace the volume database with the baked-in db3 on next boot. Use
# only when intentionally wiping state (UAT resets, rollback, etc.).
FORCE_DB_SEED=0

# ---------------------------------------------------------------------------
# Railway-managed (don't set these yourself)
# ---------------------------------------------------------------------------
# RAILWAY_ENVIRONMENT_NAME=production
# RAILWAY_VOLUME_MOUNT_PATH=/data
# PORT=8080
